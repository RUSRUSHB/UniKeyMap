{
    "description": "Caps Lock 增强：HJKL/WS方向, UN翻页YI行首尾, []上一级下一级, AD词级跳跃, BM选中, ,.单词选中, Z/X左右, Space回车, Q/E删除, C截图, FG鼠标, RV滚轮",
    "manipulators": [
        {
            "description": "基础设置：单击Esc，长按为 Hyper Key (Cmd+Opt+Ctrl+Shift)",
            "from": {
                "key_code": "caps_lock",
                "modifiers": { "optional": ["any"] }
            },
            "to": [
                {
                    "key_code": "left_shift",
                    "modifiers": ["left_command", "left_control", "left_option"]
                }
            ],
            "to_if_alone": [{ "key_code": "escape" }],
            "type": "basic"
        },
        {
            "description": "Caps + C -> 区域截图至剪切板",
            "from": {
                "key_code": "c",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [
                {
                    "key_code": "4",
                    "modifiers": ["left_command", "left_shift", "left_control"]
                }
            ],
            "type": "basic"
        },
        {
            "description": "Caps + Z/X -> 左/右",
            "from": {
                "key_code": "z",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [{ "key_code": "left_arrow" }],
            "type": "basic"
        },
        {
            "from": {
                "key_code": "x",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [{ "key_code": "right_arrow" }],
            "type": "basic"
        },
        {
            "description": "Caps + W/S/A/D -> 方向与跳跃",
            "from": {
                "key_code": "w",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [{ "key_code": "up_arrow" }],
            "type": "basic"
        },
        {
            "from": {
                "key_code": "s",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [{ "key_code": "down_arrow" }],
            "type": "basic"
        },
        {
            "description": "Caps + Q/E -> 删除",
            "from": {
                "key_code": "q",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [{ "key_code": "delete_or_backspace" }],
            "type": "basic"
        },
        {
            "from": {
                "key_code": "e",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [{ "key_code": "delete_forward" }],
            "type": "basic"
        },
        {
            "description": "Caps + 1/2 -> / 和 \\",
            "from": {
                "key_code": "1",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [{ "key_code": "slash" }],
            "type": "basic"
        },
        {
            "from": {
                "key_code": "2",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [{ "key_code": "backslash" }],
            "type": "basic"
        },
        {
            "description": "Caps + ` -> Enter",
            "from": {
                "key_code": "grave_accent_and_tilde",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [{ "key_code": "return_or_enter" }],
            "type": "basic"
        },
        {
            "description": "Caps + HJKL -> 方向键",
            "from": {
                "key_code": "h",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [{ "key_code": "left_arrow" }],
            "type": "basic"
        },
        {
            "from": {
                "key_code": "j",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [{ "key_code": "down_arrow" }],
            "type": "basic"
        },
        {
            "from": {
                "key_code": "k",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [{ "key_code": "up_arrow" }],
            "type": "basic"
        },
        {
            "from": {
                "key_code": "l",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [{ "key_code": "right_arrow" }],
            "type": "basic"
        },
        {
            "description": "Caps + U/N -> PageUp/Down",
            "from": {
                "key_code": "u",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [{ "key_code": "page_up" }],
            "type": "basic"
        },
        {
            "from": {
                "key_code": "n",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [{ "key_code": "page_down" }],
            "type": "basic"
        },
        {
            "description": "Caps + [ / ] -> 上一级/下一级 (Cmd+Up/Down)",
            "from": {
                "key_code": "open_bracket",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [
                {
                    "key_code": "up_arrow",
                    "modifiers": ["left_command"]
                }
            ],
            "type": "basic"
        },
        {
            "from": {
                "key_code": "close_bracket",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [
                {
                    "key_code": "down_arrow",
                    "modifiers": ["left_command"]
                }
            ],
            "type": "basic"
        },
        {
            "description": "Caps + Y/I -> Home/End",
            "from": {
                "key_code": "y",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [
                {
                    "key_code": "left_arrow",
                    "modifiers": ["left_command"]
                }
            ],
            "type": "basic"
        },
        {
            "from": {
                "key_code": "i",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [
                {
                    "key_code": "right_arrow",
                    "modifiers": ["left_command"]
                }
            ],
            "type": "basic"
        },
        {
            "description": "Caps + A/D -> 词级跳跃",
            "from": {
                "key_code": "a",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [
                {
                    "key_code": "left_arrow",
                    "modifiers": ["left_option"]
                }
            ],
            "type": "basic"
        },
        {
            "from": {
                "key_code": "d",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [
                {
                    "key_code": "right_arrow",
                    "modifiers": ["left_option"]
                }
            ],
            "type": "basic"
        },
        {
            "description": "Caps + B/M -> 字符级选中",
            "from": {
                "key_code": "b",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [
                {
                    "key_code": "left_arrow",
                    "modifiers": ["left_shift"]
                }
            ],
            "type": "basic"
        },
        {
            "from": {
                "key_code": "m",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [
                {
                    "key_code": "right_arrow",
                    "modifiers": ["left_shift"]
                }
            ],
            "type": "basic"
        },
        {
            "description": "Caps + ,/. -> 词级选中",
            "from": {
                "key_code": "comma",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [
                {
                    "key_code": "left_arrow",
                    "modifiers": ["left_shift", "left_option"]
                }
            ],
            "type": "basic"
        },
        {
            "from": {
                "key_code": "period",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [
                {
                    "key_code": "right_arrow",
                    "modifiers": ["left_shift", "left_option"]
                }
            ],
            "type": "basic"
        },
        {
            "description": "Caps + Space -> 回车",
            "from": {
                "key_code": "spacebar",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [{ "key_code": "return_or_enter" }],
            "type": "basic"
        },
        {
            "description": "Caps + F -> 鼠标左键",
            "from": {
                "key_code": "f",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [{ "pointing_button": "button1" }],
            "type": "basic"
        },
        {
            "description": "Caps + G -> 鼠标右键",
            "from": {
                "key_code": "g",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [{ "pointing_button": "button2" }],
            "type": "basic"
        },
        {
            "description": "Caps + R -> 滚轮上",
            "from": {
                "key_code": "r",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [{ "mouse_key": { "vertical_wheel": -32 } }],
            "type": "basic"
        },
        {
            "description": "Caps + V -> 滚轮下",
            "from": {
                "key_code": "v",
                "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
            },
            "to": [{ "mouse_key": { "vertical_wheel": 32 } }],
            "type": "basic"
        }
    ]
}